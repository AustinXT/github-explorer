---
import { SITE } from "~/lib/data";

interface Props {
  variant?: "footer" | "section" | "sidebar";
}

const { variant = "sidebar" } = Astro.props;
const base = import.meta.env.BASE_URL;
const qrSrc = `${base}${SITE.wechat.qr}`.replace(/\/{2,}/g, "/");
const name = SITE.wechat.name;
const alt = `微信公众号「${name}」二维码`;
---

{
  variant === "footer" && (
    <div class="flex items-center gap-3">
      <img
        src={qrSrc}
        alt={alt}
        width="56"
        height="56"
        loading="lazy"
        class="w-14 h-14 object-contain rounded bg-white p-0.5 border border-zinc-200 shrink-0"
      />
      <div class="leading-tight">
        <div class="text-zinc-400">微信公众号</div>
        <div class="font-medium text-zinc-700">{name}</div>
      </div>
    </div>
  )
}

{
  variant === "section" && (
    <div class="bg-white border border-zinc-200 rounded-lg p-8 flex flex-col items-center text-center">
      <img
        src={qrSrc}
        alt={alt}
        width="180"
        height="180"
        loading="lazy"
        class="w-44 h-44 object-contain rounded-lg bg-white p-2 border border-zinc-200"
      />
      <h2 class="mt-5 text-lg font-semibold text-zinc-900">
        关注公众号「{name}」
      </h2>
      <p class="mt-2 text-sm text-zinc-500 max-w-md">
        微信扫码,第一时间获取最新 GitHub 仓库深度分析与 Trending 选题。
      </p>
    </div>
  )
}

{
  variant === "sidebar" && (
    <div class="bg-white border border-zinc-200 rounded-lg p-4">
      <h3 class="text-sm font-medium text-zinc-500 mb-3">关注公众号</h3>
      <div class="flex flex-col items-center text-center">
        <img
          src={qrSrc}
          alt={alt}
          width="140"
          height="140"
          loading="lazy"
          class="w-36 h-36 object-contain rounded-lg bg-white p-1.5 border border-zinc-200"
        />
        <div class="mt-3 text-sm font-medium text-zinc-700">{name}</div>
        <div class="mt-0.5 text-xs text-zinc-400">微信扫码关注</div>
      </div>
    </div>
  )
}
